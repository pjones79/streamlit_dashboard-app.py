# Copy to .env in this folder and fill in your OpenSky OAuth client (same as firmware APIConfiguration.h).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Optional overrides (defaults match firmware)
# OPENSKY_TOKEN_URL=https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token
# OPENSKY_BASE_URL=https://opensky-network.org
# API_PORT=3001
